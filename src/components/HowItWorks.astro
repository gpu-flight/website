    border: 1px solid var(--gf-border);
    border-radius: var(--gf-radius-lg);
    padding: 24px;
  }
  .step:hover { border-color: var(--gf-border-strong); }
  .step-header {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    margin-bottom: 16px;
  }
  .step-num {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--gf-accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.875rem;
    flex-shrink: 0;
  }
  .step-header h3 {
    font-size: 1rem;
    font-weight: 600;
