---
const steps = [
  {
    num: '1',
    title: 'Add the SDK',
    desc: 'Add GPUFlight to your CMake project, then instrument your code with a single scope macro.',
    code: `# CMakeLists.txt
include(FetchContent)
FetchContent_Declare(gpufl
  GIT_REPOSITORY https://github.com/gpu-flight/gpufl-client.git
  GIT_TAG        main)
FetchContent_MakeAvailable(gpufl)
target_link_libraries(my_app PRIVATE gpufl::gpufl)`,
    lang: 'cmake',
  },
  {
    num: '2',
    title: 'Instrument Your Code',
    desc: 'One include, one init call, and wrap your kernels with GFL_SCOPE.',
    code: `#include <gpufl/gpufl.hpp>

int main() {
    gpufl::init({ .app_name = "my-training-job" });

    GFL_SCOPE("Forward Pass") {
        myKernel<<<grid, block>>>(...);
    }

    gpufl::shutdown();
    gpufl::generateReport();  // prints to stdout
}`,
    lang: 'cpp',
  },
  {
    num: '3',
    title: 'Deploy & Monitor',
    desc: 'Run the agent alongside your workload to stream data to the dashboard.',
    code: `# Stream profiling data to GPUFlight Cloud
docker run -d \\
  -v /tmp/gpufl:/var/log/gpufl \\
  -e GPUFL_HTTP_TOKEN=your-api-key \\
  gpuflight/agent:latest

# Or add always-on GPU monitoring
docker compose -f monitor.yml up -d`,
    lang: 'bash',
  },
]
---

<section class="section">
  <div class="container">
    <div class="section-header">
      <h2>Up and running in 5 minutes</h2>
      <p>Three steps. No complex setup. No agents hogging your GPU.</p>
    </div>

    <div class="steps">
      {steps.map(s => (
        <div class="step">
          <div class="step-header">
            <div class="step-num">{s.num}</div>
            <div>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
          </div>
          <pre><code>{s.code}</code></pre>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
