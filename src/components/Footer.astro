---
const year = new Date().getFullYear()
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-logo">
          <div class="logo-mark">GF</div>
          <span class="logo-text">GPUFlight</span>
        </div>
        <p class="footer-tagline">GPU monitoring and kernel profiling for production ML workloads.</p>
      </div>

      <div class="footer-col">
        <h4>Product</h4>
        <a href="/features">Features</a>
        <a href="/pricing">Pricing</a>
        <a href="https://app.gpuflight.com" target="_blank">Dashboard</a>
      </div>

      <div class="footer-col">
        <h4>Resources</h4>
        <a href="https://docs.gpuflight.com">Documentation</a>
        <a href="https://docs.gpuflight.com/docs/intro">Getting Started</a>
        <a href="https://github.com/gpu-flight" target="_blank">GitHub</a>
      </div>

    </div>

    <div class="footer-bottom">
      <span>&copy; {year} GPUFlight. All rights reserved.</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--gf-bg);
    border-top: 1px solid var(--gf-border);
    padding: 56px 24px 32px;
  }
  .footer-inner {
    max-width: var(--gf-max-width);
    margin: 0 auto;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 40px;
  }
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }
  .footer-logo .logo-mark {
    width: 26px;
    height: 26px;
    border-radius: 6px;
    background: var(--gf-accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 10px;
  }
  .footer-logo .logo-text {
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--gf-text);
  }
  .footer-tagline {
    font-size: 0.8125rem;
    color: var(--gf-text-muted);
    line-height: 1.6;
    max-width: 260px;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-col h4 {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gf-text-muted);
    margin-bottom: 4px;
  }
  .footer-col a {
    font-size: 0.8125rem;
    color: var(--gf-text-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-col a:hover {
    color: var(--gf-text);
  }
  .footer-bottom {
    border-top: 1px solid var(--gf-border);
    padding-top: 20px;
    font-size: 0.75rem;
    color: var(--gf-text-muted);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }
</style>
