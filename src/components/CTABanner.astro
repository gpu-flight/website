<section class="cta">
  <div class="container" style="text-align: center;">
    <h2>Start profiling your GPUs in 5 minutes</h2>
    <p>Free during Open Beta. No credit card required.</p>
    <div class="cta-actions">
      <a href="https://app.gpuflight.com/register" class="btn btn-primary btn-large">Create Free Account</a>
      <a href="https://docs.gpuflight.com/docs/intro" class="btn btn-secondary btn-large">Read the Docs</a>
    </div>
  </div>
</section>

<style>
  .cta {
    padding: 96px 24px;
    background: var(--gf-bg-elevated);
    border-top: 1px solid var(--gf-border);
    border-bottom: 1px solid var(--gf-border);
  }
  .cta h2 {
    font-size: 2.25rem;
    font-weight: 700;
    margin-bottom: 16px;
    letter-spacing: -0.03em;
    color: var(--gf-text);
  }
  .cta p {
    font-size: 1.0625rem;
    color: var(--gf-text-secondary);
    margin-bottom: 32px;
  }
  .cta-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  @media (max-width: 768px) {
    .cta { padding: 64px 16px; }
    .cta h2 { font-size: 1.625rem; }
  }
</style>
