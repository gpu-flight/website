---
const points = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Production-Safe',
    desc: 'Low overhead profiling that runs alongside your workload. No debugger, no replay, no kernel serialization.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
    title: 'Instruction-Level Detail',
    desc: 'SASS disassembly, PC Sampling stall analysis, and memory coalescing efficiency — per instruction, per kernel.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    title: 'Real-Time Dashboard',
    desc: 'Live GPU metrics, kernel traces, and AI-powered insights streamed to a web dashboard as your code runs.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M6 10v4M10 10v4M14 10v4M18 10v4"/></svg>`,
    title: 'Fleet-Wide Visibility',
    desc: 'Monitor every GPU across your cluster from one place. Per-host, per-device views with health gauges.',
  },
]
---

<section class="section section-alt">
  <div class="container">
    <div class="section-header">
      <h2>Built for GPU engineers</h2>
      <p>The profiling data you need, without stopping your workload.</p>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; max-width: 720px; margin: 0 auto;">
      {points.map(p => (
        <div style={`background: var(--gf-bg-card); border: 1px solid var(--gf-border); border-radius: 12px; padding: 28px; text-align: center;`}>
          <div style="color: var(--gf-accent); margin-bottom: 16px;" set:html={p.icon} />
          <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 8px; color: var(--gf-text); letter-spacing: -0.01em;">{p.title}</h3>
          <p style="font-size: 0.875rem; color: var(--gf-text-secondary); line-height: 1.65;">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
